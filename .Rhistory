)
# inspect
lon_turn_df %>%
select(-c(1:4)) %>%
map(~table(.x, useNA = "always"))
#check if median splits are ok
lon_turn_df %>%
group_by(cntry) %>%
summarise(
lon_med = median(as.numeric(lon), na.rm = TRUE),
si_med  = median(si_index, na.rm = TRUE),
# See how many people are actually "Above" the median
pct_high_lon = mean(as.numeric(lon) > lon_med, na.rm = TRUE),
pct_high_si  = mean(si_index > si_med, na.rm = TRUE)
)
#clean
rm(list = ls())
library("pacman")
p_load(tidyverse, here, haven, countrycode)
#load ess 11
raw_data <- read_dta(here("Input", "ESS11e04_1.dta"))
# select and rename
lon_turn_df <- raw_data %>%
select(
# Design & weighting
cntry,
psu, #primary sampling unit
stratum, #sampling stratum
anweight, #weights
# Dependent Variables [cite: 29, 33]
vote = vote, #did u vote?
starts_with("prtvt"), # Capture all country-specific party variables
# Plus the specific ones for de and lt
any_of(c("prtvgde1", "prtvgde2", "prtvclt1", "prtvclt2", "prtvclt3")),
# Loneliness & SI
lon = fltlnl, #loneliness
hhsize = hhmmb, #household size
marit = maritalb, #marital status
meet = sclmeet, #social meeting
relig = rlgatnd, # attending religious services
volunt = volunfp, # volounteering
discuss = inprdsc, # how many ppl discuss with
unemployed = uempla, # unemployed
# Controls
gender = gndr,
age = agea,
educ = edulvlb,
hhincome = hincfel,
health = health,
polint = polintr
)
#focus on ppl who can actually vote
lon_turn_df <- lon_turn_df %>%
filter(vote %in% c(1, 2) | is.na(vote)) #these were pepole without rights to vote (minors/criminals)
# Var type, polarity, NAs, and Factor labels
lon_turn_df <- lon_turn_df %>%
mutate(
reported_party_num = coalesce(
zap_labels(prtvgde1),
zap_labels(prtvclt1),
!!!lapply(select(., starts_with("prtv")), zap_labels)
)
) %>%
# Step B: Final Variable Cleaning
mutate(
# 1. Vote: Preserve NAs [cite: 29, 31]
vote = case_when(
vote == 1 ~ 1,
vote == 2 ~ 0,
is.na(vote) ~ NA_real_
),
# 2. Strict Turnout: 1 if voted + party; 0 if didn't vote/no party; NA if vote is NA [cite: 29, 35]
vote_strict = case_when(
is.na(vote) ~ NA_real_,
vote == 1 & !is.na(reported_party_num) ~ 1,
TRUE ~ 0
),
# 3. Loneliness: Restore as Factor [cite: 37, 39]
lon = as_factor(lon),
# --- SOCIAL ISOLATION (SI) DUMMIES (1 = Isolated) ---
# 4. Household Size [cite: 41, 43]
hhsize_iso = case_when(
hhsize == 0 ~ NA_real_,
hhsize == 1 ~ 1,
hhsize > 1  ~ 0,
TRUE ~ NA_real_
),
# 5. Marital Status: Married/Civil Union (1, 2) is Integrated [cite: 45, 47]
marit_iso = if_else(marit %in% c(1, 2), 0, 1),
# 6. Social Meetings: Meet less than once a month (1, 2) is Isolated [cite: 49, 51]
meet_iso = if_else(meet <= 2, 1, 0),
# 7. Religious Attendance: Infrequent (>=5) is Isolated [cite: 53, 55]
relig_iso = if_else(relig >= 5, 1, 0),
# 8. Volunteering: No (2) is Isolated [cite: 57, 59]
volunt_iso = if_else(volunt == 2, 1, 0),
# 9. Discussion Partners: 0 or 1 partner is Isolated [cite: 61, 63]
discuss_iso = if_else(discuss <= 1, 1, 0),
# 10. Unemployment: Actively looking (1) is Isolated [cite: 69, 71]
unemp_iso = if_else(unemployed == 1, 1, 0),
# --- CONTROLS: Restore Labels [cite: 74, 77] ---
gender = as_factor(gender),
educ = as_factor(educ),
hhincome = as_factor(hhincome),
health = as_factor(health),
polint = as_factor(polint)
)
# Select vars we actually need
lon_turn_df = lon_turn_df %>%
select(cntry:anweight, #ess vars
vote, vote_strict, #vote vars (DV)
lon, #loneliness
hhsize_iso, marit_iso, meet_iso, relig_iso, volunt_iso, discuss_iso, unemp_iso, #iso vars
gender, age, educ, hhincome #controls
)
# # inspect
# lon_turn_df %>%
#   select(-c(1:4)) %>%
#   map(~table(.x, useNA = "always"))
lon_turn_df <- lon_turn_df %>%
mutate(
# 2. Loneliness: Convert non-responses to NA and drop unused factor levels
lon = fct_recode(lon, NULL = "Refusal", NULL = "Don't know", NULL = "No answer"),
# 3. Gender: Drop "No answer" level
gender = fct_recode(gender, NULL = "No answer") %>% fct_drop(),
# 4. Education: Recode ISCED into 3 Levels (Low, Medium, High)
# Mapping based on standard ESS/ISCED groupings
educ = case_when(
educ %in% c("Not completed ISCED level 1",
"ISCED 1, completed primary education",
"General ISCED 2A, access ISCED 3A general/all 3",
"Vocational ISCED 2", "Vocational ISCED 2A/2B", "Vocational ISCED 2C") ~ "Low",
str_detect(as.character(educ), "ISCED 3|ISCED 4") ~ "Medium",
str_detect(as.character(educ), "ISCED 5|ISCED 6") ~ "High",
TRUE ~ NA_character_
) %>% factor(levels = c("Low", "Medium", "High")),
# 5. Income: Convert non-responses to NA
hhincome = fct_recode(hhincome, NULL = "Don't know", NULL = "Refusal", NULL = "No answer")
)
# inspect
lon_turn_df %>%
select(-c(1:4)) %>%
map(~table(.x, useNA = "always"))
lon_turn_df <- lon_turn_df %>%
# Create additive SI index (0-7)
mutate(
si_index = rowSums(select(., ends_with("_iso")), na.rm = FALSE)
) %>%
# Create SIL Typology
# We use country-specific medians for SI and L
group_by(cntry) %>%
mutate(
# Loneliness as numeric for median split
lon_num = as.numeric(lon),
si_median = median(si_index, na.rm = TRUE),
lon_median = median(lon_num, na.rm = TRUE),
# Typology
sil_type = case_when(
lon_num >  lon_median & si_index <= si_median ~ "High L, Low SI",
lon_num >  lon_median & si_index >  si_median ~ "High L, High SI",
lon_num <= lon_median & si_index <= si_median ~ "Low L, Low SI",
lon_num <= lon_median & si_index >  si_median ~ "Low L, High SI",
TRUE ~ NA_character_
) %>% factor(levels = c("Low L, Low SI", "Low L, High SI", "High L, Low SI", "High L, High SI"))
) %>%
ungroup() %>%
select(-c(lon_num, si_median, lon_median))
#check if median splits are ok
lon_turn_df %>%
group_by(cntry) %>%
summarise(
lon_med = median(as.numeric(lon), na.rm = TRUE),
si_med  = median(si_index, na.rm = TRUE),
# See how many people are actually "Above" the median
pct_high_lon = mean(as.numeric(lon) > lon_med, na.rm = TRUE),
pct_high_si  = mean(si_index > si_med, na.rm = TRUE)
)
#clean
rm(list = ls())
library("pacman")
p_load(tidyverse, here, haven, countrycode)
#load ess 11
raw_data <- read_dta(here("Input", "ESS11e04_1.dta"))
# select and rename
lon_turn_df <- raw_data %>%
select(
# Design & weighting
cntry,
psu, #primary sampling unit
stratum, #sampling stratum
anweight, #weights
# Dependent Variables [cite: 29, 33]
vote = vote, #did u vote?
starts_with("prtvt"), # Capture all country-specific party variables
# Plus the specific ones for de and lt
any_of(c("prtvgde1", "prtvgde2", "prtvclt1", "prtvclt2", "prtvclt3")),
# Loneliness & SI
lon = fltlnl, #loneliness
hhsize = hhmmb, #household size
marit = maritalb, #marital status
meet = sclmeet, #social meeting
relig = rlgatnd, # attending religious services
volunt = volunfp, # volounteering
discuss = inprdsc, # how many ppl discuss with
unemployed = uempla, # unemployed
# Controls
gender = gndr,
age = agea,
educ = edulvlb,
hhincome = hincfel,
health = health,
polint = polintr
)
#focus on ppl who can actually vote
lon_turn_df <- lon_turn_df %>%
filter(vote %in% c(1, 2) | is.na(vote)) #these were pepole without rights to vote (minors/criminals)
# Var type, polarity, NAs, and Factor labels
lon_turn_df <- lon_turn_df %>%
mutate(
reported_party_num = coalesce(
zap_labels(prtvgde1),
zap_labels(prtvclt1),
!!!lapply(select(., starts_with("prtv")), zap_labels)
)
) %>%
# Step B: Final Variable Cleaning
mutate(
# 1. Vote: Preserve NAs [cite: 29, 31]
vote = case_when(
vote == 1 ~ 1,
vote == 2 ~ 0,
is.na(vote) ~ NA_real_
),
# 2. Strict Turnout: 1 if voted + party; 0 if didn't vote/no party; NA if vote is NA [cite: 29, 35]
vote_strict = case_when(
is.na(vote) ~ NA_real_,
vote == 1 & !is.na(reported_party_num) ~ 1,
TRUE ~ 0
),
# 3. Loneliness: Restore as Factor [cite: 37, 39]
lon = as_factor(lon),
# --- SOCIAL ISOLATION (SI) DUMMIES (1 = Isolated) ---
# 4. Household Size [cite: 41, 43]
hhsize_iso = case_when(
hhsize == 0 ~ NA_real_,
hhsize == 1 ~ 1,
hhsize > 1  ~ 0,
TRUE ~ NA_real_
),
# 5. Marital Status: Married/Civil Union (1, 2) is Integrated [cite: 45, 47]
marit_iso = if_else(marit %in% c(1, 2), 0, 1),
# 6. Social Meetings: Meet less than once a month (1, 2) is Isolated [cite: 49, 51]
meet_iso = if_else(meet <= 2, 1, 0),
# 7. Religious Attendance: Infrequent (>=5) is Isolated [cite: 53, 55]
relig_iso = if_else(relig >= 5, 1, 0),
# 8. Volunteering: No (2) is Isolated [cite: 57, 59]
volunt_iso = if_else(volunt == 2, 1, 0),
# 9. Discussion Partners: 0 or 1 partner is Isolated [cite: 61, 63]
discuss_iso = if_else(discuss <= 1, 1, 0),
# 10. Unemployment: Actively looking (1) is Isolated [cite: 69, 71]
unemp_iso = if_else(unemployed == 1, 1, 0),
# --- CONTROLS: Restore Labels [cite: 74, 77] ---
gender = as_factor(gender),
educ = as_factor(educ),
