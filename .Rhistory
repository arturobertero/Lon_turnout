library("pacman")
p_load(tidyverse, here, haven, countrycode, sjPlot, lme4, survey)
# Export to RDS
lon_turn_df = readRDS(here("Input", "data_clean.rds"))
# # weights
# ess_design <- svydesign(
#   ids = ~psu,
#   strata = ~stratum,
#   weights = ~anweight,
#   data = lon_turn_df,
#   nest = TRUE
# )
# Model 1A: Interaction (Loneliness * Centered SI)
m1a_list <- lon_turn_df %>%
group_split(cntry) %>%
set_names(unique(lon_turn_df$cntry)) %>%
map(~ glm(vote ~ lon * si_centered + gender + age_centered + educ + hhincome,
data = .x, family = binomial(link = "logit")))
# Model 1B: Typology (4-slot SIL)
m1b_list <- lon_turn_df %>%
group_split(cntry) %>%
set_names(unique(lon_turn_df$cntry)) %>%
map(~ glm(vote ~ sil_type + gender + age_centered + educ + hhincome,
data = .x, family = binomial(link = "logit")))
# Save tables for sample countries
tab_model(m1a_list$AT, m1a_list$BE, m1a_list$DE,
file = here("Output", "Table_M1_Unweighted_Logits.html"))
# Average European interaction with random intercepts/slopes [cite: 121, 129]
m2a <- glmer(vote ~ lon * si_centered + gender + age_centered + educ + hhincome +
(1 + si_centered | cntry),
data = lon_turn_df, family = binomial)
# Model 2B: Multilevel Typology
# Across Europe, which mismatch profiles are most disengaged? [cite: 124, 130]
m2b <- glmer(vote ~ sil_type + gender + age_centered + educ + hhincome +
(1 | cntry),
data = lon_turn_df, family = binomial)
# Save Comparison Table
tab_model(m2a, m2b, file = here("Output", "Table_M2_Unweighted_Multilevel.html"))
