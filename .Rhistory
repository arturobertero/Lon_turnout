plot = sil_composition_plot,
width = 12,
height = 7,
dpi = 600)
# Aggregate data on turnout (ESS and IDEA)
survey_agg <- lon_turn_df %>%
group_by(cntry) %>%
summarise(
official = mean(official_turnout_lag, na.rm = TRUE),
vote = mean(vote, na.rm = TRUE),
vote_strict = mean(vote_strict, na.rm = TRUE),
.groups = "drop"
)
# Data prep: calculate bias from benchmark
deviation_data <- survey_agg %>%
mutate(
bias_vote = vote - official,
bias_vote_strict = vote_strict - official
) %>%
# Order countries by their standard over-reporting
arrange(bias_vote) %>%
mutate(cntry = factor(cntry, levels = cntry)) %>%
pivot_longer(
cols = c(bias_vote, bias_vote_strict),
names_to = "measure",
values_to = "deviation"
) %>%
mutate(
measure = case_when(
measure == "bias_vote" ~ "Self-reported\nvote choice",
measure == "bias_vote_strict" ~ "Successful\nvote recall"
),
# factor levels
measure = factor(measure, levels = c("Self-reported\nvote choice", "Successful\nvote recall"))
)
# Plot the deviation from zero
p_deviation <- ggplot(deviation_data, aes(x = deviation, y = cntry, color = measure)) +
geom_vline(xintercept = 0, color = "#0D0887FF", linewidth = 1.2) +
geom_line(aes(group = cntry), color = "grey", linewidth = 0.8, alpha = 0.5) +
geom_point(size = 3.5) +
scale_x_continuous(
labels = scales::percent_format(),
breaks = scales::pretty_breaks(n = 8)
) +
scale_color_manual(values = c(
"Self-reported\nvote choice" = "#6A00A8FF",
"Successful\nvote recall" = "#FCA636FF"
)) +
labs(
x = "Deviation from Official Benchmark",
y = "Country",
color = "Measure"
) +
theme(
panel.grid.major.y = element_line(color = "grey90", linetype = "dashed"),
panel.grid.major.x = element_line(color = "grey90", linetype = "dashed"),
axis.title.x = element_text(size = 14, face = "bold"),
axis.title.y = element_text(size = 14, face = "bold"),
axis.text.y = element_text(size = 10, face = "bold"),
axis.text.x = element_text(size = 11),
legend.key.height = unit(2, "lines")
)
# Save
ggsave(here("Output", "Supplement", "Turnout_Deviation_Magma.png"), p_deviation, width = 12, height = 16, dpi = 600)
# Formal valiadtion
print("--- Preparing Error Data ---")
validation_stats <- survey_agg %>%
mutate(
# absolute error (distance from Official) for both measures
error_vote = abs(vote - official),
error_vote_strict = abs(vote_strict - official)
)
# Mean Absolute Error
print("--- 1. Mean Absolute Error (MAE) ---")
mae_summary <- validation_stats %>%
summarise(
MAE_self_report = mean(error_vote, na.rm = TRUE),
MAE_strict_recall = mean(error_vote_strict, na.rm = TRUE),
Improvement = MAE_self_report - MAE_strict_recall
)
print(mae_summary)
# Paired T-Test
print("--- 2. Paired T-Test on Errors ---")
error_ttest <- t.test(
validation_stats$error_vote,
validation_stats$error_vote_strict,
paired = TRUE,
alternative = "greater"
)
print(error_ttest)
# Correlation with Official
print("--- 3. Correlations with Official Turnout ---")
cor_vote <- cor.test(validation_stats$official, validation_stats$vote)
cor_strict <- cor.test(validation_stats$official, validation_stats$vote_strict)
cat("Correlation (Official vs. Self-Report):", round(cor_vote$estimate, 3),
"| p-value:", format.pval(cor_vote$p.value), "\n")
cat("Correlation (Official vs. Strict Recall):", round(cor_strict$estimate, 3),
"| p-value:", format.pval(cor_strict$p.value), "\n")
