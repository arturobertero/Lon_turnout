drop_na(vote_strict, sil_exhaustive, gender, age_decades_centered, educ, hhincome) %>%
count(sil_exhaustive) %>%
mutate(pop_share = n / sum(n))
# 3. Merge predictions and CREATE HTML LABELS
plot_df <- left_join(pred_turnout, group_sizes, by = "sil_exhaustive") %>%
mutate(
# Use the helper function and <br> for HTML line breaks instead of \n
label = case_when(
sil_exhaustive == "None/Almost none & 0-1: Low ISO"  ~ paste0(style_box("Low", "SI"), "<br><br>", style_box("Low", "Lon.")),
sil_exhaustive == "Some of the time & 0-1: Low ISO"    ~ paste0(style_box("Low", "SI"), "<br><br>", style_box("Mid", "Lon.")),
sil_exhaustive == "Most/All the time & 0-1: Low ISO"   ~ paste0(style_box("Low", "SI"), "<br><br>", style_box("High", "Lon.")),
sil_exhaustive == "None/Almost none & 2: Mid ISO"      ~ paste0(style_box("Mid", "SI"), "<br><br>", style_box("Low", "Lon.")),
sil_exhaustive == "Some of the time & 2: Mid ISO"      ~ paste0(style_box("Mid", "SI"), "<br><br>", style_box("Mid", "Lon.")),
sil_exhaustive == "Most/All the time & 2: Mid ISO"     ~ paste0(style_box("Mid", "SI"), "<br><br>", style_box("High", "Lon.")),
sil_exhaustive == "None/Almost none & 3+: High ISO"    ~ paste0(style_box("High", "SI"), "<br><br>", style_box("Low", "Lon.")),
sil_exhaustive == "Some of the time & 3+: High ISO"    ~ paste0(style_box("High", "SI"), "<br><br>", style_box("Mid", "Lon.")),
sil_exhaustive == "Most/All the time & 3+: High ISO"   ~ paste0(style_box("High", "SI"), "<br><br>", style_box("High", "Lon.")),
TRUE ~ as.character(sil_exhaustive)
)
)
# 4. Build the Ordered Bubble Plot
p_dilemma <- ggplot(plot_df, aes(
x = reorder(label, desc(predicted_turnout)),
y = predicted_turnout
)) +
geom_errorbar(aes(ymin = conf_low, ymax = conf_high), width = 0.1, color = "grey60", alpha = 0.6) +
geom_point(aes(size = pop_share), fill = magma_pal[3], shape = 21, color = "white", stroke = 1.2) +
geom_text(aes(label = percent(pop_share, accuracy = 1)),
color = "white", fontface = "bold", size = 3.5) +
scale_y_continuous(labels = scales::percent_format(accuracy = 1)) +
scale_size_continuous(range = c(8, 26), guide = "none") +
labs(
x = NULL,
y = "Predicted Turnout Probability",
title = NULL,
subtitle = NULL,
caption = "Note: Bubble size indicates the percentage of the sample in each typology group.\nPredicted probabilities are population-averaged marginal effects, calculated holding controls at their means and generalizing across all countries."
) +
theme_paper() +
theme(
panel.grid.minor = element_blank(),
panel.grid.major.x = element_blank(),
panel.grid.major.y = element_line(color = "grey90", linetype = "dashed"),
# FIX: Use element_markdown() so ggplot reads our HTML strings!
# lineheight adjusts the vertical space between the two stacked boxes.
axis.text.x = element_markdown(angle = 0, hjust = 0.5, face = "bold", size = 10, color = "black", lineheight = 1.2),
plot.margin = margin(t = 20, r = 20, b = 20, l = 20),
legend.position = "none",
plot.caption = element_text(hjust = 0, face = "italic", color = "grey40", size = 9, margin = margin(t = 15))
)
# 5. Save the plot
ggsave(
here("Output", "Supplement", "Figure_Targeting_Dilemma_ColoredAxis.png"),
p_dilemma,
width = 13, # Bumped slightly wider again to accommodate the beautiful new pillboxes
height = 7.5, # Bumped height slightly for the double-stacked boxes
dpi = 600,
bg = "white"
)
