# 3. Clean and Filter results
# 3. Clean, Filter, and Fix variable names for plotting
m1_m2_results <- m1_m2_weighted %>%
filter(term %in% c("lon_n", "si_n")) %>%
mutate(
# Create the 'predictor' column required by facet_wrap
predictor = factor(model, levels = c("Loneliness (M1)", "Social Isolation (M2)")),
significant = conf.low > 1 | conf.high < 1
)
# 3. Simplified Plotting Function
p_m1_m2_simple <- ggplot(m1_m2_results, aes(x = reorder(cntry, estimate),
y = estimate, color = significant)) +
geom_hline(yintercept = 1, linetype = "dashed", color = "black") +
geom_pointrange(aes(ymin = conf.low, ymax = conf.high), size = 0.5) +
# Now 'predictor' exists and will work with facet_wrap
facet_wrap(~predictor, scales = "free_y", ncol = 1) +
coord_flip() +
scale_color_manual(values = c("FALSE" = "grey70", "TRUE" = "#d7191c")) +
theme(
strip.background = element_rect(fill = "grey95", color = NA),
strip.text = element_text(face = "bold"),
axis.text.y = element_text(size = 7),
legend.position = "none",
panel.grid.minor = element_blank()
) +
labs(
title = "Turnout Odds Ratios: Loneliness vs. Social Isolation",
subtitle = "Odds Ratio < 1 indicates a negative effect. Red = Significant (p < .05).",
x = "Country",
y = "Odds Ratio (Exponentiated Coefficients)",
caption = "Weighted Analysis (anweight). Controls: Age, Gender, Education, Income."
)
# 4. Save
ggsave(here("Output", "Models", "M1_M2.png"),
p_m1_m2_simple, width = 10, height = 12)
# 1. Run Weighted Models and Get Predictions per Country
m3_probs_clean <- lon_turn_df %>%
group_by(cntry) %>%
group_split() %>%
map_dfr(function(df_country) {
# Create the country-specific survey design [cite: 99, 106]
des <- svydesign(ids = ~psu, strata = ~stratum, weights = ~anweight,
data = df_country, nest = TRUE)
# Fit weighted model [cite: 93, 113]
# We use sil_type (the 4-group typology)
m3 <- svyglm(vote ~ sil_type + gender + age_centered + educ + hhincome,
design = des, family = quasibinomial())
# Generate predicted probabilities using ggeffects (survey-aware)
# We hold controls at their typical values
preds <- predict_response(m3, terms = "sil_type") %>%
as_tibble() %>%
rename(sil_type = x, prob = predicted, lower = conf.low, upper = conf.high) %>%
mutate(cntry = unique(df_country$cntry))
return(preds)
})
# 2. Define Plotting Function (No changes needed to your logic here)
plot_m3_by_country <- function(data_subset, batch_name) {
ggplot(data_subset, aes(x = sil_type, y = prob, color = sil_type)) +
geom_pointrange(aes(ymin = lower, ymax = upper), size = 0.6) +
facet_wrap(~cntry, ncol = 3) +
scale_y_continuous(labels = scales::percent_format(), limits = c(0, 1.0)) +
scale_color_brewer(palette = "RdYlBu", direction = -1) +
theme(
axis.text.x = element_blank(),
axis.ticks.x = element_blank(),
strip.background = element_rect(fill = "grey95", color = NA),
strip.text = element_text(face = "bold"),
legend.position = "bottom",
legend.text = element_text(size = 8),
panel.grid.minor = element_blank()
) +
labs(
title = paste("The Turnout Gap: Loneliness & Isolation -", batch_name),
subtitle = "Weighted Predicted Probabilities (svyglm). Controls: Gender, Age, Educ, Income.",
x = NULL, y = "Prob. of Voting",
color = "Typology Group",
caption = "Analysis weights (anweight), clustering (psu), and strata applied[cite: 37, 80]."
)
}
# 3. Batch and Save (Same as your previous logic)
unique_countries <- unique(m3_probs_clean$cntry)
p_m3_b1 <- plot_m3_by_country(filter(m3_probs_clean, cntry %in% unique_countries[1:15]), "Batch 1")
p_m3_b2 <- plot_m3_by_country(filter(m3_probs_clean, cntry %in% unique_countries[16:30]), "Batch 2")
ggsave(here("Output", "Models", "M3_Probabilities_Batch1.png"), p_m3_b1, width = 12, height = 15)
ggsave(here("Output", "Models", "M3_Probabilities_Batch2.png"), p_m3_b2, width = 12, height = 15)
# 1. Run M4 for each country using survey-weighted logistic regression
m4_weighted_results <- lon_turn_df %>%
group_by(cntry) %>%
group_split() %>%
map_dfr(function(df_country) {
# Create the country-specific survey design (crucial for valid SEs)
# Corrects for selection probabilities and clustering [cite: 15, 31, 39]
des <- svydesign(ids = ~psu, strata = ~stratum, weights = ~anweight,
data = df_country, nest = TRUE)
# M4: Run weighted logistic regression (svyglm)
# vote = lon_n + si_n + controls
m4 <- svyglm(vote ~ lon_n + si_n + gender + age_centered + educ + hhincome,
design = des, family = quasibinomial())
# Extract results using broom::tidy and exponentiate for Odds Ratios
tidy(m4, conf.int = TRUE, exponentiate = TRUE) %>%
mutate(cntry = unique(df_country$cntry))
})
# 2. Process and Filter for Plotting
m4_results <- m4_weighted_results %>%
filter(term %in% c("lon_n", "si_n")) %>%
mutate(
predictor = if_else(term == "lon_n", "Loneliness Penalty (adj.)", "Social Isolation Penalty (adj.)"),
significant = conf.low > 1 | conf.high < 1
)
# 3. Create the Odds Ratio Plot
p_m4_odds <- ggplot(m4_results, aes(x = reorder(cntry, estimate), y = estimate, color = significant)) +
geom_hline(yintercept = 1, linetype = "dashed", color = "black") +
geom_pointrange(aes(ymin = conf.low, ymax = conf.high), size = 0.5) +
facet_wrap(~predictor, scales = "free_y", ncol = 1) + # Adjusting to free_y for better sorting
coord_flip() +
scale_color_manual(values = c("FALSE" = "grey70", "TRUE" = "#d7191c")) +
theme(
strip.background = element_rect(fill = "grey95", color = NA),
strip.text = element_text(face = "bold"),
axis.text.y = element_text(size = 7),
legend.position = "none",
panel.grid.minor = element_blank()
) +
labs(
title = "M4: Independent Turnout Penalties (Weighted Additive Model)",
subtitle = "Odds Ratios < 1 indicate lower turnout. Each effect is adjusted for the other.",
x = "Country",
y = "Odds Ratio (Exponentiated Coefficients)",
caption = "Weighted Analysis (anweight) accounting for clustering (psu). Controls: Age, Gender, Education, Income."
)
# 4. Save
ggsave(here("Output", "Models", "M4_Additive_OddsRatios.png"),
p_m4_odds, width = 10, height = 12)
# 1. Run M5 Interaction Model for each country using svyglm
m5_weighted_results <- lon_turn_df %>%
group_by(cntry) %>%
group_split() %>%
map_dfr(function(df_country) {
# Define the survey design for this country [cite: 80, 102]
# This accounts for weights (anweight), clusters (psu), and strata (stratum)
des <- svydesign(ids = ~psu, strata = ~stratum, weights = ~anweight,
data = df_country, nest = TRUE)
# M5: Interaction Model (vote ~ lon_n * si_n + controls)
# R expands '*' to include main effects and the interaction term [cite: 99]
m5 <- svyglm(vote ~ lon_n * si_n + gender + age_centered + educ + hhincome,
design = des, family = quasibinomial())
# Extract coefficients (Keep as Log-Odds for the interaction term)
tidy(m5, conf.int = TRUE) %>%
mutate(cntry = unique(df_country$cntry))
})
# 2. Extract and Process only the Interaction Term
m5_interaction_results <- m5_weighted_results %>%
filter(term == "lon_n:si_n") %>%
# In log-odds, significance is based on whether the CI excludes 0 [cite: 27]
mutate(significant = conf.low > 0 | conf.high < 0) %>%
ungroup()
# 3. Create the Significance Plot
p_m5_interaction_sig <- ggplot(m5_interaction_results, aes(x = reorder(cntry, estimate),
y = estimate,
color = significant)) +
geom_hline(yintercept = 0, linetype = "dashed", color = "black") +
geom_pointrange(aes(ymin = conf.low, ymax = conf.high), size = 0.6) +
coord_flip() +
# Red for significant interactions as per your previous style
scale_color_manual(values = c("FALSE" = "grey70", "TRUE" = "#e41a1c")) +
theme(
axis.text.y = element_text(size = 7),
legend.position = "none",
panel.grid.minor = element_blank()
) +
labs(
title = "Significance of the Double Burden Interaction (Weighted M5)",
subtitle = "Interaction Coefficient (lon_n:si_n). Negative = Loneliness hurts more as Isolation increases.",
x = "Country",
y = "Interaction Coefficient (Log-Odds Estimate)",
caption = "Weighted Analysis (anweight) with complex design (psu/stratum). Red = Significant (p < .05)."
)
# 4. Save
ggsave(here("Output", "Models", "M5_Interaction_Significance.png"),
p_m5_interaction_sig, width = 8, height = 10)
# ==========================================
# CHUNK 1: MULTILEVEL MODELS & LRT TEST (FIXED)
# ==========================================
library(lme4)
library(tidyverse)
# 0. Prep: Scale weights and fix variable scales for the optimizer
mlm_df <- lon_turn_df %>%
filter(!is.na(vote), !is.na(lon_centered), !is.na(si_centered)) %>%
mutate(
weights_scaled = anweight / mean(anweight, na.rm = TRUE),
# Fix the Eigenvalue warning by putting age on a smaller scale (decades)
age_decades_centered = age_centered / 10
)
# # fix pol int
# mlm_df <- mlm_df %>%
#   mutate(polint_centered = polint_centered * -1)
#
# # 2. Re-run the matrix to verify victory!
# mlm_df %>%
#   select(vote, partisanship, polint_centered) %>%
#   cor(use = "pairwise.complete.obs") %>%
#   round(3)
# Update control formula with the rescaled age
controls <- "gender + age_decades_centered + educ + hhincome"
# --- THE RANDOM SLOPES JUSTIFICATION ---
print("Fitting MM0 (Intercept Only)...")
f0 <- as.formula(paste("vote ~ lon_centered +", controls, "+ (1 | cntry)"))
# suppressWarnings hides the annoying but harmless non-integer binomial warning
mm0_intercept <- suppressWarnings(
glmer(f0, data = mlm_df, family = binomial, weights = weights_scaled,
control = glmerControl(optimizer = "bobyqa"))
)
print("Fitting MM1 (Random Slopes)...")
f1 <- as.formula(paste("vote ~ lon_centered +", controls, "+ (1 + lon_centered | cntry)"))
mm1_base <- suppressWarnings(
glmer(f1, data = mlm_df, family = binomial, weights = weights_scaled,
control = glmerControl(optimizer = "bobyqa"))
)
# STATISTICAL TEST
print("Likelihood Ratio Test: Random Intercepts vs. Random Slopes")
anova(mm0_intercept, mm1_base)
# --- FITTING THE REST OF THE BOSS MODELS ---
print("Fitting MM2 (Additive)...")
f2 <- as.formula(paste("vote ~ lon_centered + si_centered +", controls, "+ (1 + lon_centered + si_centered | cntry)"))
mm2_add <- suppressWarnings(
glmer(f2, data = mlm_df, family = binomial, weights = weights_scaled,
control = glmerControl(optimizer = "bobyqa", optCtrl = list(maxfun = 1e5)))
)
print("Fitting MM3 (Interaction)...")
f3 <- as.formula(paste("vote ~ lon_centered * si_centered +", controls, "+ (1 + lon_centered + si_centered | cntry)"))
mm3_int <- suppressWarnings(
glmer(f3, data = mlm_df, family = binomial, weights = weights_scaled,
control = glmerControl(optimizer = "bobyqa", optCtrl = list(maxfun = 1e5)))
)
print("Fitting MM4 (Typology)...")
f4 <- as.formula(paste("vote ~ sil_type +", controls, "+ (1 | cntry)"))
mm4_typo <- suppressWarnings(
glmer(f4, data = mlm_df, family = binomial, weights = weights_scaled,
control = glmerControl(optimizer = "bobyqa"))
)
print("Fitting MM5 (Robustness)...")
f5 <- as.formula(paste("vote ~ lon_centered + si_centered + polint_centered + partisanship +", controls, "+ (1 + lon_centered + si_centered | cntry)"))
mm5_rob <- suppressWarnings(
glmer(f5, data = mlm_df, family = binomial, weights = weights_scaled,
control = glmerControl(optimizer = "bobyqa", optCtrl = list(maxfun = 2e5)))
)
print("Fitting MM6 (Macro Interaction)...")
f6 <- as.formula(paste("vote ~ lon_centered * official_turnout_lag + si_centered + polint_centered + partisanship +", controls, "+ (1 + lon_centered + si_centered | cntry)"))
mm6_macro <- suppressWarnings(
glmer(f6, data = mlm_df, family = binomial, weights = weights_scaled,
control = glmerControl(optimizer = "bobyqa", optCtrl = list(maxfun = 2e5)))
)
print("All models fitted successfully!")
# ==========================================
# CHUNK 2: REGRESSION TABLES (INDIVIDUAL EXPORTS)
# ==========================================
library(sjPlot)
# 0. Shared Label Dictionary (Keeps labels consistent across all tables)
# sjPlot will match these to the variables when they appear in a model
common_labels <- c(
"(Intercept)" = "Intercept",
"lon_centered" = "Loneliness (Centered)",
"si_centered" = "Social Isolation (Centered)",
"genderFemale" = "Gender (Female)", # Adjust based on your exact factor level
"age_decades_centered" = "Age (Decades, Centered)",
"educMedium" = "Education: Medium",
"educHigh" = "Education: High",
"polint_centered" = "Pol. Interest (Centered)",
"partisanship1" = "Partisanship (Yes)", # Adjust based on your exact dummy level
"official_turnout_lag" = "Official Turnout (Lagged)",
"lon_centered:si_centered" = "Interaction: Lon x SI",
"lon_centered:official_turnout_lag" = "Cross-Level: Lon x Turnout Lag"
)
# 1. Structural Justification Table (MM0 vs MM1)
# Proves to reviewers that random slopes are necessary
tab_model(
mm0_intercept, mm1_base,
show.re.var = TRUE,
show.icc = TRUE,
pred.labels = common_labels,
dv.labels = c("MM0: Intercept Only", "MM1: Random Slopes"),
title = "Table S1: Justification of Random Slopes for Loneliness",
file = here("Output", "Models", "Table_Justification_MM0_MM1.html")
)
# 2. MM1: Baseline Loneliness Penalty
tab_model(
mm1_base,
show.re.var = TRUE, show.icc = TRUE,
pred.labels = common_labels,
dv.labels = "MM1: Baseline Loneliness",
title = "Table 1: Multilevel Model - Baseline Loneliness Penalty",
file = here("Output", "Models", "Table_MM1_Base.html")
)
# 3. MM2: Additive Model (Loneliness + SI)
tab_model(
mm2_add,
show.re.var = TRUE, show.icc = TRUE,
pred.labels = common_labels,
dv.labels = "MM2: Additive Penalties",
title = "Table 2: Multilevel Model - Additive Social Deficits",
file = here("Output", "Models", "Table_MM2_Additive.html")
)
# 4. MM3: The Double Burden (Interaction)
tab_model(
mm3_int,
show.re.var = TRUE, show.icc = TRUE,
pred.labels = common_labels,
dv.labels = "MM3: Interaction",
title = "Table 3: Multilevel Model - The Double Burden Interaction",
file = here("Output", "Models", "Table_MM3_Interaction.html")
)
# 5. MM4: The Typology Model
# Note: Typology uses specific categorical labels
tab_model(
mm4_typo,
show.re.var = TRUE, show.icc = TRUE,
dv.labels = "MM4: Typology",
title = "Table 4: Multilevel Model - Social Isolation & Loneliness Typology",
file = here("Output", "Models", "Table_MM4_Typology.html")
)
# 6. MM5: Fully Controlled Robustness Model
tab_model(
mm5_rob,
show.re.var = TRUE, show.icc = TRUE,
pred.labels = common_labels,
dv.labels = "MM5: Robustness Controls",
title = "Table 5: Multilevel Model - Robustness with Political Motivation",
file = here("Output", "Models", "Table_MM5_Robustness.html")
)
# 7. MM6: Macro-Context Cross-Level Interaction
tab_model(
mm6_macro,
show.re.var = TRUE, show.icc = TRUE,
pred.labels = common_labels,
dv.labels = "MM6: Macro Interaction",
title = "Table 6: Multilevel Model - Cross-Level Moderation by National Turnout",
file = here("Output", "Models", "Table_MM6_Macro.html")
)
# ==========================================
# CHUNK 3: PLOTTING THE RESULTS (ADAPTED)
# ==========================================
# 1. The Caterpillar Plots (MM2)
# The 'grid = FALSE' argument stops sjPlot from combining them into one faceted plot
p_caterpillar_list <- plot_model(mm2_add, type = "re", sort.est = "sort.all", grid = FALSE)
# NOW [[1]] is the actual Intercept ggplot, and [[2]] is the Loneliness slope ggplot!
p_cat_intercept <- p_caterpillar_list[[1]] +
labs(title = "National Turnout Baselines (Random Intercepts)",
y = "Deviation from European Average (Log-Odds)")
ggsave(here("Output", "Models", "MM2_Caterpillar_Intercept.png"), p_cat_intercept, width = 8, height = 10)
p_cat_lon <- p_caterpillar_list[[2]] +
labs(title = "National Variation in the Loneliness Penalty (Random Slopes)",
y = "Deviation from European Average Penalty")
ggsave(here("Output", "Models", "MM2_Caterpillar_Loneliness.png"), p_cat_lon, width = 8, height = 10)
# Save the Random Slopes for Loneliness (National Variation in Penalty)
p_cat_lon <- p_caterpillar_list[[2]] +
labs(title = "National Variation in the Loneliness Penalty (Random Slopes)",
y = "Deviation from European Average Penalty")
ggsave(here("Output", "Models", "MM2_Caterpillar_Loneliness.png"), p_cat_lon, width = 8, height = 10)
# 2. MM4 Plot: The Typology 'Staircase'
# Visually proves the severe penalty for the "Doubly Burdened"
preds_mm4 <- predict_response(mm4_typo, terms = "sil_type")
p_mm4 <- plot(preds_mm4) +
scale_y_continuous(labels = scales::percent_format()) +
labs(title = "The Turnout Gap: Social Isolation & Loneliness",
subtitle = "Predicted Probabilities of Voting (European Average)",
x = "Social Integration Typology",
y = "Probability of Voting") +
theme(axis.text.x = element_text(angle = 45, hjust = 1, face = "bold"))
ggsave(here("Output", "Models", "MM4_Typology_Staircase.png"), p_mm4, width = 8, height = 6)
# 3. MM5 Plot: The Robustness Forest Plot
# Shows Loneliness & SI coefficients holding their own against Political Interest & Partisanship
p_mm5_forest <- plot_model(mm5_rob, type = "est",
transform = "exp", # Plots Odds Ratios
vline.color = "black",
terms = c("lon_centered", "si_centered", "polint_centered", "partisanship"),
title = "Do Social Deficits Survive Political Controls?",
axis.labels = c("Partisanship (Yes)", "Political Interest",
"Social Isolation", "Loneliness")) +
labs(y = "Odds Ratios (Values < 1 indicate turnout penalty)")
ggsave(here("Output", "Models", "MM5_Robustness_Forest.png"), p_mm5_forest, width = 8, height = 5)
View(lon_turn_df)
# 1. Define the shared control formula
controls <- "gender + age_decades_centered + educ + hhincome"
# 2. Fit Model A: Standard vote, Lagged Turnout as a Control (NO INTERACTION)
print("Fitting Macro Control Model (Standard DV)...")
f_macro_control <- as.formula(paste("vote ~ lon_centered + si_centered + polint_centered + partisanship + official_turnout_lag +", controls, "+ (1 + lon_centered + si_centered | cntry)"))
mm_macro_control <- suppressWarnings(
glmer(f_macro_control, data = mlm_df, family = binomial, weights = weights_scaled,
control = glmerControl(optimizer = "bobyqa", optCtrl = list(maxfun = 2e5)))
)
# 3. Fit Model B: Strict vote, Lagged Turnout as a Control
print("Fitting Macro Control Model (Strict DV)...")
f_macro_strict <- as.formula(paste("vote_strict ~ lon_centered + si_centered + polint_centered + partisanship + official_turnout_lag +", controls, "+ (1 + lon_centered + si_centered | cntry)"))
mm_macro_strict <- suppressWarnings(
glmer(f_macro_strict, data = mlm_df, family = binomial, weights = weights_scaled,
control = glmerControl(optimizer = "bobyqa", optCtrl = list(maxfun = 2e5)))
)
# 4. Generate the Comparison Table
# Re-define common labels just in case this is run independently
strict_labels <- c(
"(Intercept)" = "Intercept",
"lon_centered" = "Loneliness (Centered)",
"si_centered" = "Social Isolation (Centered)",
"polint_centered" = "Pol. Interest (Centered)",
"partisanship1" = "Partisanship (Yes)",
"official_turnout_lag" = "Official Turnout (Lagged)",
"genderFemale" = "Gender (Female)",
"age_decades_centered" = "Age (Decades, Centered)",
"educMedium" = "Education: Medium",
"educHigh" = "Education: High"
)
tab_model(
mm_macro_control, mm_macro_strict,
show.re.var = TRUE, show.icc = TRUE,
pred.labels = strict_labels,
dv.labels = c("Standard Vote Recall", "Strict Vote Recall (Party Named)"),
title = "Table 7: Robustness Checks - Macro Controls and Strict Turnout",
file = here("Output", "Models", "Table_Robustness_StrictVote.html")
)
print("Models fitted and Table 7 saved!")
