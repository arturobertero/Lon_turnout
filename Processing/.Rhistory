ggsave(
here("Output", "Supplement", "Figure_Targeting_Funnel_Dynamic.png"),
final_slide_plot,
width = 10,     # Slightly tighter width forces text to appear larger
height = 6.5,   # Adjust based on whether your Beamer is 4:3 or 16:9
bg = "white"
)
