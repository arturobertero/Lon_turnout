library(ggeffects)
library(sjPlot)
library(ggplot2)
# --- 1. MM2 Caterpillars: National Deviations ---
# 'grid = FALSE' separates the plots.
# [[1]] = Intercepts, [[2]] = Loneliness Slopes, [[3]] = SI Slopes
p_caterpillar_list <- plot_model(mm2_add, type = "re", sort.est = "sort.all", grid = FALSE)
# 1a. Intercepts (Baseline Turnout)
p_cat_int <- p_caterpillar_list[[1]] +
labs(title = "National Turnout Baselines (Random Intercepts)", y = "Deviation from EU Average")
ggsave(here("Output", "Models", "MM2_Caterpillar_Intercept.png"), p_cat_int, width = 8, height = 10)
# 1b. Loneliness Random Slopes
p_cat_lon <- p_caterpillar_list[[2]] +
labs(title = "National Variation in the Loneliness Penalty", y = "Deviation from EU Average Penalty")
ggsave(here("Output", "Models", "MM2_Caterpillar_Loneliness.png"), p_cat_lon, width = 8, height = 10)
# 1c. Social Isolation (SI) Random Slopes
p_cat_si <- p_caterpillar_list[[3]] +
labs(title = "National Variation in the Social Isolation Penalty", y = "Deviation from EU Average Penalty")
ggsave(here("Output", "Models", "MM2_Caterpillar_SI.png"), p_cat_si, width = 8, height = 10)
# --- 2. MM3 Plot: The "Additive" Proof ---
# Plotting the non-significant interaction to visually prove the lines are parallel.
# We predict probabilities at average (-1), and high (+1) Social Isolation.
preds_mm3 <- predict_response(mm3_int, terms = c("lon_centered", "si_centered [-1, 1]"))
p_mm3 <- plot(preds_mm3) +
scale_y_continuous(labels = scales::percent_format()) +
labs(title = "MM3: The Additive Reality of Social Deficits",
subtitle = "Parallel lines indicate no interaction; the penalties stack.",
x = "Loneliness (Centered)", y = "Probability of Voting", color = "Social Isolation")
ggsave(here("Output", "Models", "MM3_Additive_Lines.png"), p_mm3, width = 7, height = 5)
# --- 3. MM4 Plot: Typology 'Staircase' ---
preds_mm4 <- predict_response(mm4_typo, terms = "sil_type")
p_mm4 <- plot(preds_mm4) +
scale_y_continuous(labels = scales::percent_format()) +
labs(title = "MM4: The Turnout Gap (Social Isolation & Loneliness)",
subtitle = "Predicted Probabilities of Voting (European Average)",
x = "Social Integration Typology", y = "Probability of Voting") +
theme(axis.text.x = element_text(angle = 45, hjust = 1, face = "bold"))
ggsave(here("Output", "Models", "MM4_Typology_Staircase.png"), p_mm4, width = 8, height = 6)
# --- 4. MM5 Plot: The Robustness Forest Plot ---
p_mm5_forest <- plot_model(mm5_rob, type = "est",
transform = "exp",
vline.color = "black",
terms = c("lon_centered", "si_centered", "polint_centered", "partisanship"),
title = "MM5: Do Social Deficits Survive Political Controls?",
axis.labels = c("Partisanship (Yes)", "Political Interest",
"Social Isolation", "Loneliness")) +
labs(y = "Odds Ratios (Values < 1 indicate turnout penalty)")
ggsave(here("Output", "Models", "MM5_Robustness_Forest.png"), p_mm5_forest, width = 8, height = 5)
# --- 5. STANDALONE ROBUSTNESS: Strict Vote vs Standard Vote ---
# We use plot_models() to plot two different regressions side-by-side.
# rm.terms removes the demographic controls so the plot only highlights the variables of interest.
p_strict_comparison <- plot_models(mm_macro_control, mm_macro_strict,
transform = "exp",
m.labels = c("Standard Vote Recall", "Strict Vote (Named Party)"),
rm.terms = c("genderFemale", "age_decades_centered", "educMedium",
"educHigh", "hhincomeCoping on present income",
"hhincomeDifficult on present income",
"hhincomeVery difficult on present income",
"official_turnout_lag"),
title = "Table 7 Visualized: Strict Turnout Recall",
legend.title = "Dependent Variable") +
geom_hline(yintercept = 1, linetype = "dashed", color = "black") +
labs(y = "Odds Ratios")
ggsave(here("Output", "Models", "Robustness_Strict_vs_Standard.png"), p_strict_comparison, width = 9, height = 6)
# Test if it is also ok to use random slopes for BOTH SI and L
print("Running nested models to justify both Loneliness and SI random slopes...")
# Make sure controls are defined if running separately
controls <- "gender + age_decades_centered + educ + hhincome"
# 1. Base Fixed Effects Model with INTERCEPT ONLY
f_test0 <- as.formula(paste("vote ~ lon_centered + si_centered +", controls, "+ (1 | cntry)"))
test0_intercept <- suppressWarnings(
glmer(f_test0, data = mlm_df, family = binomial, weights = weights_scaled,
control = glmerControl(optimizer = "bobyqa"))
)
# 2. Add FIRST Random Slope (Loneliness)
f_test1 <- as.formula(paste("vote ~ lon_centered + si_centered +", controls, "+ (1 + lon_centered | cntry)"))
test1_lon_slope <- suppressWarnings(
glmer(f_test1, data = mlm_df, family = binomial, weights = weights_scaled,
control = glmerControl(optimizer = "bobyqa"))
)
# 3. Add SECOND Random Slope (Social Isolation) - This is structurally identical to your MM2!
f_test2 <- as.formula(paste("vote ~ lon_centered + si_centered +", controls, "+ (1 + lon_centered + si_centered | cntry)"))
test2_both_slopes <- suppressWarnings(
glmer(f_test2, data = mlm_df, family = binomial, weights = weights_scaled,
control = glmerControl(optimizer = "bobyqa", optCtrl = list(maxfun = 1e5)))
)
# --- THE ULTIMATE LIKELIHOOD RATIO TEST ---
print("Nested Likelihood Ratio Test: Intercept -> +Loneliness Slope -> +Both Slopes")
anova(test0_intercept, test1_lon_slope, test2_both_slopes)
