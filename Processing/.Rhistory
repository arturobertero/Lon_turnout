polint_centered = (polint_n - mean(polint_n)) / sd(polint_n),
lon_centered    = (lon_n - mean(lon_n)) / sd(lon_n),
si_centered     = (si_n - mean(si_n)) / sd(si_n)
) %>%
ungroup() %>%
# STEP 4: FINAL MLM TRANSFORMATIONS
mutate(
age_decades_centered = age_centered / 10,
weights_scaled = anweight / mean(anweight),
# The exhaustive typology relies on the 3-level categorical vars, so it remains unaffected
sil_exhaustive = interaction(lon, si_levels, sep = " & "),
sil_exhaustive = relevel(sil_exhaustive, ref = "None/Almost none & 0-1: Low ISO")
)
mm4_robust <- suppressWarnings(glmer(
vote_strict ~ sil_exhaustive + gender + age_decades_centered + educ + hhincome + (1 | cntry),
data = mlm_df, family = binomial, weights = weights_scaled,
control = glmerControl(optimizer = "bobyqa", optCtrl = list(maxfun = 2e5))
))
library(ggeffects)
library(dplyr)
library(ggplot2)
library(scales)
# ==========================================
# FIGURE: THE POLICY TARGETING DILEMMA (SINGLE COLOR)
# ==========================================
# 1. Get Predicted Turnout Probabilities
pred_turnout <- ggpredict(mm4_robust, terms = "sil_exhaustive") %>%
as_tibble() %>%
rename(sil_exhaustive = x, predicted_turnout = predicted, conf_low = conf.low, conf_high = conf.high)
# 2. Calculate actual population share
group_sizes <- mlm_df %>%
drop_na(vote_strict, sil_exhaustive, gender, age_decades_centered, educ, hhincome) %>%
count(sil_exhaustive) %>%
mutate(pop_share = n / sum(n))
# 3. Merge predictions and CREATE SHORT LABELS
plot_df <- left_join(pred_turnout, group_sizes, by = "sil_exhaustive") %>%
mutate(
# Exact mapping based on your provided table output
label = case_when(
sil_exhaustive == "None/Almost none & 0-1: Low ISO"  ~ "Low SI\nLow Lon.",
sil_exhaustive == "Some of the time & 0-1: Low ISO"    ~ "Low SI\nMid Lon.",
sil_exhaustive == "Most/All the time & 0-1: Low ISO"   ~ "Low SI\nHigh Lon.",
sil_exhaustive == "None/Almost none & 2: Mid ISO"      ~ "Mid SI\nLow Lon.",
sil_exhaustive == "Some of the time & 2: Mid ISO"      ~ "Mid SI\nMid Lon.",
sil_exhaustive == "Most/All the time & 2: Mid ISO"     ~ "Mid SI\nHigh Lon.",
sil_exhaustive == "None/Almost none & 3+: High ISO"    ~ "High SI\nLow Lon.",
sil_exhaustive == "Some of the time & 3+: High ISO"    ~ "High SI\nMid Lon.",
sil_exhaustive == "Most/All the time & 3+: High ISO"   ~ "High SI\nHigh Lon.",
TRUE ~ as.character(sil_exhaustive)
)
# The dynamic text_color logic is gone because the bubble is now a solid color
)
# 4. Build the Ordered Bubble Plot
p_dilemma <- ggplot(plot_df, aes(
x = reorder(label, desc(predicted_turnout)),
y = predicted_turnout
)) +
geom_errorbar(aes(ymin = conf_low, ymax = conf_high), width = 0.1, color = "grey60", alpha = 0.6) +
# FIX 1: Set a single magma color for all bubbles. magma_pal[3] or [4] is usually a nice deep shade.
geom_point(aes(size = pop_share), fill = magma_pal[3], shape = 21, color = "white", stroke = 1.2) +
# FIX 2: Text is hardcoded to white so it contrasts perfectly with the dark magma bubble
geom_text(aes(label = percent(pop_share, accuracy = 1)),
color = "white", fontface = "bold", size = 3.5) +
scale_y_continuous(labels = scales::percent_format(accuracy = 1)) +
# Keep the size scaling, but ensure no legend is drawn
scale_size_continuous(range = c(8, 26), guide = "none") +
# FIX 3: Added the explanatory caption!
labs(
x = NULL,
y = "Predicted Turnout Probability",
title = NULL,
subtitle = NULL,
caption = "Note: Bubble size indicates the percentage of the sample in each typology group.\nPredicted probabilities are population-averaged marginal effects, calculated holding controls at their means and generalizing across all countries."
) +
theme_paper() +
theme(
panel.grid.minor = element_blank(),
panel.grid.major.x = element_blank(),
panel.grid.major.y = element_line(color = "grey90", linetype = "dashed"),
axis.text.x = element_text(angle = 0, hjust = 0.5, face = "bold", size = 10, color = "black"),
plot.margin = margin(t = 20, r = 20, b = 20, l = 20),
# FIX 4: Obliterate the legend entirely and format the caption so it looks professional
legend.position = "none",
plot.caption = element_text(hjust = 0, face = "italic", color = "grey40", size = 9, margin = margin(t = 15))
)
# 5. Save the plot
ggsave(
here("Output", "Supplement", "Figure_Targeting_Dilemma_Ordered.png"),
p_dilemma,
width = 12,
height = 7,
dpi = 600,
bg = "white"
)
