library(ggeffects)
library(dplyr)
library(ggplot2)
library(scales)
library(ggtext) # <-- NEW MAGIC WEAPON
# ==========================================
# FIGURE: THE POLICY TARGETING DILEMMA (WITH HTML AXIS BOXES)
# ==========================================
# --- HELPER FUNCTION FOR HTML BOXES ---
# This creates a colored CSS box for each label based on intensity
style_box <- function(level, label_text) {
bg_color <- case_when(
level == "Low" ~ "#E0E0E0",  # Light Grey (Low intensity)
level == "Mid" ~ "#FFB74D",  # Warm Orange (Mid intensity)
level == "High" ~ "#E53935"  # Deep Red (High intensity)
)
# Ensure white text on the dark red boxes for readability
text_color <- ifelse(level == "High", "white", "black")
# Return the HTML string
sprintf("<span style='background-color:%s; color:%s; padding:3px 5px; border-radius:4px;'>%s %s</span>",
bg_color, text_color, level, label_text)
}
# 1. Get Predicted Turnout Probabilities
pred_turnout <- ggpredict(mm4_robust, terms = "sil_exhaustive") %>%
as_tibble() %>%
rename(sil_exhaustive = x, predicted_turnout = predicted, conf_low = conf.low, conf_high = conf.high)
# 2. Calculate actual population share
